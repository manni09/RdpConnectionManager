<Window x:Class="RdpManager.ConnectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Editor" 
        Height="780" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="550" MinWidth="440"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradientBrush}" 
                Padding="28,24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" 
                                  Color="#000000" Opacity="0.12"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource PrimaryGradientBrush}" CornerRadius="12" Padding="12">
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="20" 
                               Foreground="White"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="New Connection" 
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Configure your connection settings"
                               FontSize="12" Foreground="#94A3B8"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel>
                <!-- Basic Info -->
                <TextBlock Text="BASIC INFORMATION" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,14"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" 
                        Padding="22" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                        Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Connection Type" FontSize="13" Margin="0,0,0,8"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                        <ComboBox x:Name="ConnectionTypeCombo" Margin="0,0,0,18" SelectionChanged="ConnectionTypeCombo_SelectionChanged">
                            <ComboBoxItem Content="RDP (Remote Desktop)" IsSelected="True"/>
                            <ComboBoxItem Content="SSH (Secure Shell)"/>
                        </ComboBox>
                        
                        <TextBlock Text="Display Name" FontSize="13" Margin="0,0,0,8"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                        <TextBox x:Name="NameBox" Margin="0,0,0,18"/>

                        <TextBlock Text="Hostname / IP Address *" FontSize="13" Margin="0,0,0,8"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                        <TextBox x:Name="HostnameBox" Margin="0,0,0,18"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Group" FontSize="13" Margin="0,0,0,8"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                <ComboBox x:Name="GroupCombo" IsEditable="True"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="PortLabel" Text="Port" FontSize="13" Margin="0,0,0,8"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                <TextBox x:Name="PortBox" Text="3389"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Credentials -->
                <TextBlock Text="CREDENTIALS" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,14"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" 
                        Padding="22" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                        Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Username" FontSize="13" Margin="0,0,0,8"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                        <TextBox x:Name="UsernameBox" Margin="0,0,0,18"/>

                        <StackPanel x:Name="DomainPanel">
                            <TextBlock Text="Domain (optional)" FontSize="13" Margin="0,0,0,8"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                            <TextBox x:Name="DomainBox" Margin="0,0,0,18"/>
                        </StackPanel>

                        <TextBlock Text="Password" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <PasswordBox x:Name="PasswordBox"/>
                        <TextBlock Text=" Password is encrypted and stored securely"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- SSH Authentication (only visible for SSH) -->
                <StackPanel x:Name="SshAuthPanel" Visibility="Collapsed">
                    <TextBlock Text="SSH AUTHENTICATION" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                            Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Authentication Method" FontSize="13" Margin="0,0,0,6"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <ComboBox x:Name="SshAuthMethodCombo" Margin="0,0,0,16">
                                <ComboBoxItem Content="Password Only" IsSelected="True"/>
                                <ComboBoxItem Content="Private Key Only"/>
                                <ComboBoxItem Content="Private Key + Password"/>
                            </ComboBox>
                            
                            <StackPanel x:Name="PrivateKeyPanel">
                                <TextBlock Text="Private Key File" FontSize="13" Margin="0,0,0,6"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PrivateKeyPathBox" Grid.Column="0" IsReadOnly="True"/>
                                    <Button Grid.Column="1" Content="Browse..." Click="BrowsePrivateKey_Click"
                                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="12,6"/>
                                </Grid>
                                
                                <TextBlock Text="Private Key Passphrase (if encrypted)" FontSize="13" Margin="0,0,0,6"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <PasswordBox x:Name="PrivateKeyPassphraseBox"/>
                                <TextBlock Text=" Leave empty if your key is not encrypted"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Display Settings (RDP only) -->
                <StackPanel x:Name="RdpSettingsPanel">
                    <TextBlock Text="DISPLAY SETTINGS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="FullScreenCheck" Content="Full Screen" IsChecked="True" Margin="0,0,0,12"/>
                        <Grid x:Name="ResolutionGrid" Visibility="Collapsed" Margin="30,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="WidthBox" Grid.Column="0" Text="1920"/>
                            <TextBlock Grid.Column="1" Text="    " VerticalAlignment="Center" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="HeightBox" Grid.Column="2" Text="1080"/>
                        </Grid>
                        <CheckBox x:Name="MultiMonitorCheck" Content="Use Multiple Monitors" Margin="0,0,0,12"/>
                        <CheckBox x:Name="AdminCheck" Content="Admin/Console Session" Margin="0,0,0,12"/>
                        <CheckBox x:Name="SmartSizingCheck" Content="Auto Resize Display" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="DynamicResolutionCheck" Content="Auto Refresh on Resize" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Device Redirection -->
                <TextBlock Text="DEVICE REDIRECTION" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="ClipboardCheck" Content="Clipboard" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="PrintersCheck" Content="Printers" Margin="0,0,0,12"/>
                        <CheckBox x:Name="DrivesCheck" Content="Local Drives" Margin="0,0,0,12"/>
                        <CheckBox x:Name="SmartCardsCheck" Content="Smart Cards" Margin="0,0,0,12"/>
                        <CheckBox x:Name="PortsCheck" Content="Serial/Parallel Ports" Margin="0,0,0,12"/>
                        <CheckBox x:Name="PnPDevicesCheck" Content="Plug and Play Devices"/>
                    </StackPanel>
                </Border>

                <!-- Audio Settings -->
                <TextBlock Text="AUDIO SETTINGS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Remote Audio Playback" FontSize="13" Margin="0,0,0,8"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="AudioPlaybackCombo" Margin="0,0,0,16">
                            <ComboBoxItem Content="Play on this computer" IsSelected="True"/>
                            <ComboBoxItem Content="Play on remote computer"/>
                            <ComboBoxItem Content="Do not play"/>
                        </ComboBox>
                        <CheckBox x:Name="AudioCaptureCheck" Content="Enable microphone redirection" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Performance Settings -->
                <TextBlock Text="PERFORMANCE" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" 
                        Padding="22" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                        Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <CheckBox x:Name="DesktopCompositionCheck" Content="Desktop Composition" IsChecked="True" Margin="0,0,0,14"/>
                        <CheckBox x:Name="FontSmoothingCheck" Content="Font Smoothing" IsChecked="True" Margin="0,0,0,14"/>
                        <CheckBox x:Name="ThemesCheck" Content="Visual Themes" IsChecked="True" Margin="0,0,0,14"/>
                        <CheckBox x:Name="WindowDragCheck" Content="Show window contents while dragging" IsChecked="True" Margin="0,0,0,14"/>
                        <CheckBox x:Name="MenuAnimationsCheck" Content="Menu and window animations" Margin="0,0,0,14"/>
                        <CheckBox x:Name="BitmapCachingCheck" Content="Bitmap caching" IsChecked="True" Margin="0,0,0,14"/>
                        <CheckBox x:Name="CompressionCheck" Content="Enable compression" IsChecked="True" Margin="0,0,0,14"/>
                        <CheckBox x:Name="NetworkAutoDetectCheck" Content="Auto-detect network quality" IsChecked="True"/>
                    </StackPanel>
                </Border>
                </StackPanel>
                <!-- End of RDP Settings Panel -->

                <!-- Description -->
                <TextBlock Text="NOTES" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,14"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" 
                        Padding="22" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                        Effect="{StaticResource CardShadow}">
                    <TextBox x:Name="DescriptionBox" AcceptsReturn="True" TextWrapping="Wrap" 
                             Height="90" VerticalScrollBarVisibility="Auto" BorderThickness="0"
                             Background="Transparent"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer / Buttons -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0"
                Padding="28,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="-2" Direction="90" 
                                  Color="#000000" Opacity="0.06"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Width="110" Click="Cancel_Click"/>
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                        Width="120" Margin="14,0,0,0" Click="Save_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                        <TextBlock Text=" Save" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
