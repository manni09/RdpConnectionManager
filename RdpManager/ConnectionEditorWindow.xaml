<Window x:Class="RdpManager.ConnectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Editor" 
        Height="750" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="400"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,20">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="New Connection" 
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Enter connection details below"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel>
                <!-- Basic Info -->
                <TextBlock Text="BASIC INFORMATION" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Display Name" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox x:Name="NameBox" Margin="0,0,0,16"/>

                        <TextBlock Text="Hostname / IP Address *" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox x:Name="HostnameBox" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Group" FontSize="13" Margin="0,0,0,6"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <ComboBox x:Name="GroupCombo" IsEditable="True"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port" FontSize="13" Margin="0,0,0,6"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBox x:Name="PortBox" Text="3389"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Credentials -->
                <TextBlock Text="CREDENTIALS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Username" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox x:Name="UsernameBox" Margin="0,0,0,16"/>

                        <TextBlock Text="Domain (optional)" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox x:Name="DomainBox" Margin="0,0,0,16"/>

                        <TextBlock Text="Password" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <PasswordBox x:Name="PasswordBox"/>
                        <TextBlock Text=" Password is encrypted and stored securely"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Display Settings -->
                <TextBlock Text="DISPLAY SETTINGS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="FullScreenCheck" Content="Full Screen" IsChecked="True" Margin="0,0,0,12"/>
                        <Grid x:Name="ResolutionGrid" Visibility="Collapsed" Margin="30,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="WidthBox" Grid.Column="0" Text="1920"/>
                            <TextBlock Grid.Column="1" Text="    " VerticalAlignment="Center" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="HeightBox" Grid.Column="2" Text="1080"/>
                        </Grid>
                        <CheckBox x:Name="MultiMonitorCheck" Content="Use Multiple Monitors" Margin="0,0,0,12"/>
                        <CheckBox x:Name="AdminCheck" Content="Admin/Console Session" Margin="0,0,0,12"/>
                        <CheckBox x:Name="SmartSizingCheck" Content="Auto Resize Display" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="DynamicResolutionCheck" Content="Auto Refresh on Resize" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Device Redirection -->
                <TextBlock Text="DEVICE REDIRECTION" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="ClipboardCheck" Content="Clipboard" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="PrintersCheck" Content="Printers" Margin="0,0,0,12"/>
                        <CheckBox x:Name="DrivesCheck" Content="Local Drives" Margin="0,0,0,12"/>
                        <CheckBox x:Name="SmartCardsCheck" Content="Smart Cards" Margin="0,0,0,12"/>
                        <CheckBox x:Name="PortsCheck" Content="Serial/Parallel Ports" Margin="0,0,0,12"/>
                        <CheckBox x:Name="PnPDevicesCheck" Content="Plug and Play Devices"/>
                    </StackPanel>
                </Border>

                <!-- Audio Settings -->
                <TextBlock Text="AUDIO SETTINGS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Remote Audio Playback" FontSize="13" Margin="0,0,0,8"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="AudioPlaybackCombo" Margin="0,0,0,16">
                            <ComboBoxItem Content="Play on this computer" IsSelected="True"/>
                            <ComboBoxItem Content="Play on remote computer"/>
                            <ComboBoxItem Content="Do not play"/>
                        </ComboBox>
                        <CheckBox x:Name="AudioCaptureCheck" Content="Enable microphone redirection" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Performance Settings -->
                <TextBlock Text="PERFORMANCE" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox x:Name="DesktopCompositionCheck" Content="Desktop Composition" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="FontSmoothingCheck" Content="Font Smoothing" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="ThemesCheck" Content="Visual Themes" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="WindowDragCheck" Content="Show window contents while dragging" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="MenuAnimationsCheck" Content="Menu and window animations" Margin="0,0,0,12"/>
                        <CheckBox x:Name="BitmapCachingCheck" Content="Bitmap caching" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="CompressionCheck" Content="Enable compression" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="NetworkAutoDetectCheck" Content="Auto-detect network quality" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Description -->
                <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                        Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <TextBox x:Name="DescriptionBox" AcceptsReturn="True" TextWrapping="Wrap" 
                             Height="80" VerticalScrollBarVisibility="Auto"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer / Buttons -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Width="100" Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="Save" Style="{StaticResource PrimaryButton}"
                        Width="100" Margin="12,0,0,0" Click="Save_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
