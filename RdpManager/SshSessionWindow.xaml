<Window x:Class="RdpManager.SshSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SSH Session" 
        Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Terminal Colors -->
        <SolidColorBrush x:Key="TerminalBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TerminalForeground" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TerminalSelectionBrush" Color="#264F78"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Toolbar -->
        <Border x:Name="ToolbarBorder" Grid.Row="0" Background="#2D2D2D" 
                BorderBrush="#3F3F3F" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="ConnectionTitle" Text="SSH Session" 
                               Foreground="#FFFFFF" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="4,0,12,0"/>
                    <Border x:Name="StatusIndicator" Width="10" Height="10" 
                            CornerRadius="5" Background="#4CAF50" 
                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Connected" 
                               Foreground="#888888" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="CopyButton" Content="Copy" Click="Copy_Click"
                            Style="{StaticResource SecondaryButton}" 
                            Padding="12,4" Margin="0,0,8,0" FontSize="12"/>
                    <Button x:Name="PasteButton" Content="Paste" Click="Paste_Click"
                            Style="{StaticResource SecondaryButton}" 
                            Padding="12,4" Margin="0,0,8,0" FontSize="12"/>
                    <Button x:Name="DisconnectButton" Content="Disconnect" Click="Disconnect_Click"
                            Style="{StaticResource SecondaryButton}" 
                            Padding="12,4" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Terminal Area -->
        <Border Grid.Row="1" Background="{StaticResource TerminalBackground}">
            <ScrollViewer x:Name="TerminalScroller" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource TerminalBackground}"
                          PreviewMouseWheel="TerminalScroller_PreviewMouseWheel">
                <RichTextBox x:Name="TerminalOutput"
                             Background="{StaticResource TerminalBackground}"
                             Foreground="{StaticResource TerminalForeground}"
                             FontFamily="Consolas, Courier New, monospace"
                             FontSize="14"
                             IsReadOnly="False"
                             AcceptsReturn="False"
                             AcceptsTab="False"
                             BorderThickness="0"
                             Padding="8"
                             VerticalScrollBarVisibility="Disabled"
                             PreviewKeyDown="TerminalOutput_PreviewKeyDown"
                             PreviewTextInput="TerminalOutput_PreviewTextInput"
                             SelectionBrush="{StaticResource TerminalSelectionBrush}">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="LineHeight" Value="18"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>
            </ScrollViewer>
        </Border>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#2D2D2D" 
                BorderBrush="#3F3F3F" BorderThickness="0,1,0,0" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="ConnectionInfo" Grid.Column="0"
                           Text="Not connected" Foreground="#888888" 
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="SessionDuration" Grid.Column="1"
                           Text="00:00:00" Foreground="#888888" 
                           FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
