<Window x:Class="RdpManager.RdpSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Desktop Session" 
        Height="800" Width="1200"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="Manual"
        Background="#1E1E1E"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- RDP Host Container (now full height) -->
        <Border Grid.Row="0" x:Name="RdpContainer" Background="#000000">
            <WindowsFormsHost x:Name="WfHost" Background="#000000"/>
        </Border>

        <!-- Hover trigger area at top -->
        <Border Grid.Row="0" Height="5" VerticalAlignment="Top" Background="Transparent"
                MouseEnter="TopTrigger_MouseEnter"/>

        <!-- Floating Toolbar (hidden by default, shows on hover) -->
        <Border x:Name="ToolbarBorder" Grid.Row="0" VerticalAlignment="Top"
                Background="#E0202020" Padding="10,8" Visibility="Collapsed"
                MouseLeave="Toolbar_MouseLeave">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Connection Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🖥️" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ConnectionNameText" Text="Remote Desktop" 
                               FontSize="14" FontWeight="SemiBold" Foreground="White" 
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ConnectionHostText" Text="" 
                               FontSize="12" Foreground="#888888" 
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Text="(Press Esc to show/hide toolbar)" 
                               FontSize="11" Foreground="#666666" 
                               VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="FullScreenBtn" Content="⛶ Full Screen" 
                            Click="FullScreen_Click" Margin="0,0,8,0"
                            Background="#3D3D3D" Foreground="White" 
                            BorderThickness="0" Padding="12,6" Cursor="Hand"/>
                    <Button x:Name="DisconnectBtn" Content="✕ Disconnect" 
                            Click="Disconnect_Click"
                            Background="#C42B1C" Foreground="White" 
                            BorderThickness="0" Padding="12,6" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar (also hidden by default) -->
        <Border x:Name="StatusBarBorder" Grid.Row="1" Background="#2D2D2D" Padding="10,6" Visibility="Collapsed">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="8" Height="8" Fill="#4CAF50" 
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Connected" 
                               FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="ResolutionText" Text="" 
                           FontSize="12" Foreground="#666666" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
