<Window x:Class="RdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:RdpManager.Converters"
        Title="RDP Connection Manager" 
        Height="650" Width="950"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:PasswordSetConverter x:Key="PasswordSetConverter"/>
        <converters:ActiveSessionConverter x:Key="ActiveSessionConverter"/>
        <converters:HideDefaultGroupConverter x:Key="HideDefaultGroupConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header / Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="" FontSize="24" VerticalAlignment="Center"/>
                    <TextBlock Text="RDP Manager" FontSize="20" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Quick Connect -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="40,0">
                    <TextBox x:Name="QuickConnectBox" Width="280"
                             Text="{Binding QuickConnectHost, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="QuickConnectBox_KeyDown"/>
                    <Button Content="Connect" Style="{StaticResource PrimaryButton}" 
                            Margin="8,0,0,0" Click="QuickConnect_Click"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="+ New" Style="{StaticResource PrimaryButton}" 
                            Click="AddConnection_Click" ToolTip="Add new connection (Ctrl+N)"/>
                    <Button Content="Import" Style="{StaticResource SecondaryButton}" 
                            Margin="8,0,0,0" Click="Import_Click"/>
                    <Button Content="Export" Style="{StaticResource SecondaryButton}" 
                            Margin="8,0,0,0" Click="Export_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Connection List Panel -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search -->
                    <Border Grid.Row="0" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBox x:Name="SearchBox" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Text=" Search connections..." IsHitTestVisible="False"
                                       Foreground="#999999" Margin="14,0,0,0"
                                       VerticalAlignment="Center" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- List -->
                    <ListBox x:Name="ConnectionList" Grid.Row="1"
                             ItemsSource="{Binding FilteredConnections}"
                             SelectedItem="{Binding SelectedConnection}"
                             ItemContainerStyle="{StaticResource ConnectionListItem}"
                             Background="Transparent" BorderThickness="0"
                             MouseDoubleClick="ConnectionList_MouseDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                            Background="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                        <Grid>
                                            <TextBlock Text="🖥️" FontSize="22" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <!-- Active session indicator -->
                                            <Ellipse Width="12" Height="12" 
                                                     Fill="#4CAF50" Stroke="White" StrokeThickness="2"
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                     Margin="0,0,-2,-2"
                                                     Visibility="{Binding Id, Converter={StaticResource ActiveSessionConverter}}"/>
                                        </Grid>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" 
                                                   FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ConnectionString}" FontSize="12" 
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Column="2" Background="#E5F1FB" CornerRadius="6"
                                            Padding="10,4" VerticalAlignment="Center"
                                            Visibility="{Binding Group, Converter={StaticResource HideDefaultGroupConverter}}">
                                        <TextBlock Text="{Binding Group}" FontSize="11" 
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsListEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                        <TextBlock Text="No connections yet" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="Click '+ New' to add your first connection" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Details Panel -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedConnection.DisplayName}" 
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SelectedConnection.ConnectionString}" 
                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Details -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="CONNECTION DETAILS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Username" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedConnection.Username, TargetNullValue='Not set'}" 
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            </Grid>
                            
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Domain" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedConnection.Domain, TargetNullValue='Not set'}" 
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            </Grid>
                            
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Password" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding SelectedConnection.EncryptedPassword, Converter={StaticResource PasswordSetConverter}}" 
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                            </Grid>

                            <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8"/>
                            <TextBlock Text="{Binding SelectedConnection.Description, TargetNullValue='No description'}"
                                       TextWrapping="Wrap" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Text="SETTINGS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8"/>
                            <WrapPanel>
                                <Border Background="#E5F1FB" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding SelectedConnection.FullScreen, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Full Screen" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                </Border>
                                <Border Background="#E5F1FB" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding SelectedConnection.RedirectClipboard, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Clipboard" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                </Border>
                                <Border Background="#E5F1FB" CornerRadius="6" Padding="8,4" Margin="0,0,6,6"
                                        Visibility="{Binding SelectedConnection.AdminSession, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Admin" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Actions -->
                    <Border Grid.Row="2" Padding="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Button Content="  Connect" Style="{StaticResource PrimaryButton}" 
                                    HorizontalAlignment="Stretch" Click="Connect_Click"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Edit" Style="{StaticResource SecondaryButton}" 
                                        HorizontalAlignment="Stretch" Click="EditConnection_Click"/>
                                <Button Grid.Column="2" Content="Delete" Style="{StaticResource SecondaryButton}" 
                                        HorizontalAlignment="Stretch" Click="DeleteConnection_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock HorizontalAlignment="Right" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="{Binding ConnectionCount, Mode=OneWay}"/>
                    <Run Text=" connections"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
